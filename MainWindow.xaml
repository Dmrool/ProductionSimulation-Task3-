<Window x:Class="ProductionSimulation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ProductionSimulation.ViewModels"
        Title="Симуляция производства" Height="650" Width="950"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="➕ Добавить линию" Command="{Binding AddCommand}" Margin="0,0,10,0" Padding="12,6"/>
            <Button Content="🗑 Удалить" Command="{Binding RemoveCommand}" Padding="12,6"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Simulations}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="6" Margin="8" Padding="12" Width="420" Background="White">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15" Margin="0,0,0,8"/>

                                <Canvas Height="80" Background="#F8F9FA" Margin="0,0,0,10" ClipToBounds="True">
                                    <TextBlock Canvas.Left="15" Canvas.Top="28" Text="🔧 Станок" FontSize="12"/>
                                    <TextBlock Canvas.Left="135" Canvas.Top="28" Text="👨‍🔧 Фрезер" FontSize="12"/>
                                    <TextBlock Canvas.Left="255" Canvas.Top="28" Text="🚛 Погрузчик" FontSize="12"/>

                                    <Ellipse Width="22" Height="22" Fill="{Binding PartColor}" 
                                             Canvas.Left="{Binding PartX, FallbackValue=0}" Canvas.Top="25" 
                                             RenderTransformOrigin="0.5,0.5"/>
                                </Canvas>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="▶ Старт" Command="{Binding StartCommand}" Margin="0,0,4,0" Padding="8,4"/>
                                    <Button Content="⏹ Стоп" Command="{Binding StopCommand}" Margin="0,0,4,0" Padding="8,4"/>
                                    <Button Content="➕ Добавить деталь" Command="{Binding ProducePartCommand}" Padding="8,4" 
        Background="#E3F2FD" BorderBrush="#2196F3"/>
                                </StackPanel>

                                <ListBox ItemsSource="{Binding Log}" Height="110" FontFamily="Consolas" FontSize="11" 
                                         VirtualizingPanel.IsVirtualizing="True" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         BorderBrush="#E0E0E0" Padding="4"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>